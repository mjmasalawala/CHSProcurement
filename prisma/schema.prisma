// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// A login identity. Separate from role — see unified-platform-architecture.md Section 3.
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  // Null if the user only ever signs in via Google.
  passwordHash String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  roleAssignments         RoleAssignment[]
  bids                    Bid[]
  recommendedRequirements Requirement[]
  passwordResetTokens     PasswordResetToken[]
  quotationApprovals      QuotationApproval[]
  proposedChanges         ProposedChange[]     @relation("ProposedChangesProposer")
  approvedChanges         ProposedChange[]     @relation("ProposedChangesApprover")
}

// Forgot-password flow (landing-page-and-auth-flow-spec.md) — same
// single-use-token shape as Invite, but not tied to a RoleAssignment since
// it's not granting access, just letting an existing login set a new
// password.
model PasswordResetToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

enum EntityType {
  VENDOR_COMPANY
  SOCIETY
  PLATFORM
}

enum RoleName {
  VENDOR_OWNER
  VENDOR_STAFF
  MANAGER
  CHAIRMAN
  SECRETARY
  TREASURER
  OPS_VENDOR_QUEUE
  OPS_SOCIETY_QUEUE
  SUPER_ADMIN
}

enum RoleAssignmentStatus {
  // Created by an invite/registration approval, not yet accepted.
  PENDING
  ACTIVE
  // Owner-deactivated (Vendor Staff, v1) — past submissions stay attributed
  // to this assignment's user even after deactivation
  // (vendor-registration-portal-spec.md Section 2).
  DEACTIVATED
}

// Links a User to a specific entity (a Vendor Company or a Society) with a role
// and permission set. A User can hold multiple RoleAssignments (e.g. a Manager
// across several Societies). See unified-platform-architecture.md Section 3.
//
// entityId is a loose reference by design (entityType tells you which table —
// VendorCompany or Society — it points into; Prisma can't express a single FK
// that targets either table, so referential integrity here is app-level, not
// DB-level). PLATFORM roles (ProSoc Ops/Super Admin) have no entity, so
// entityId is null for those.
model RoleAssignment {
  id          String               @id @default(cuid())
  userId      String
  user        User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  entityType  EntityType
  entityId    String?
  role        RoleName
  // Effective permission strings for this assignment, seeded from role
  // defaults at creation time (see src/lib/permissions.ts) and independently
  // reassignable later without a code change, per the architecture doc.
  permissions String[]
  status      RoleAssignmentStatus @default(ACTIVE)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  invite Invite?

  @@index([userId])
  @@index([entityType, entityId])
}

// Generic invite-acceptance mechanism (landing-page-and-auth-flow-spec.md
// Section 4), reused for Secretary/Manager/Chairman/Treasurer/Vendor Staff
// activation. Not used by Vendor Owner registration, which creates
// credentials directly at signup time (product decision, 2026-07-09 — see
// DEVELOPMENT_PLAN.md).
model Invite {
  id               String         @id @default(cuid())
  token            String         @unique
  email            String
  roleAssignmentId String         @unique
  roleAssignment   RoleAssignment @relation(fields: [roleAssignmentId], references: [id], onDelete: Cascade)
  expiresAt        DateTime
  acceptedAt       DateTime?
  createdAt        DateTime       @default(now())
}

enum EntityStatus {
  PENDING_VERIFICATION
  ACTIVE
  REJECTED
  SUSPENDED
}

enum BusinessType {
  PROPRIETORSHIP
  PARTNERSHIP
  PRIVATE_LIMITED
  LLP
  OTHER
}

// Admin-managed, shared across Vendor registration, Society registration, and
// requirement creation — unified-platform-architecture.md Section 6.
model Category {
  id     String  @id @default(cuid())
  name   String  @unique
  // Soft-disable only — deactivating must not delete historical data tied to
  // it (admin-portal-spec.md Section 5).
  active Boolean @default(true)

  vendorCompanies VendorCompany[]
  requirements    Requirement[]
}

model City {
  id     String  @id @default(cuid())
  name   String  @unique
  active Boolean @default(true)

  vendorCompanies VendorCompany[]
  societies       Society[]
}

enum CategoryRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

// A vendor's "this trade isn't on your list" request, submitted alongside
// registration but never blocking it — vendor-registration-portal-spec.md
// Section 5. Goes into an Admin approval queue (M3).
model CategoryRequest {
  id              String                @id @default(cuid())
  name            String
  status          CategoryRequestStatus @default(PENDING)
  reason          String?
  vendorCompanyId String?
  vendorCompany   VendorCompany?        @relation(fields: [vendorCompanyId], references: [id], onDelete: SetNull)
  createdAt       DateTime              @default(now())
}

// vendor-registration-portal-spec.md Section 4.
model VendorCompany {
  id                String       @id @default(cuid())
  name              String
  businessType      BusinessType
  ownerName         String
  ownerPhone        String
  ownerEmail        String       @unique
  registeredAddress String
  gstNumber         String?
  panNumber         String?
  yearsInBusiness   Int?
  description       String?
  // Free-form, repeatable — supplementary metadata, not a matching input in
  // v1 (Section 6).
  societiesServiced String[]     @default([])
  status            EntityStatus @default(PENDING_VERIFICATION)
  rejectionReason   String?

  // Standard tier (Section 4.2) — schema-only, no v1 GUI. Nullable so
  // exposing them later needs no migration.
  tradeLicenseNumber    String?
  tradeLicenseExpiry    DateTime?
  insurancePolicyNumber String?
  insuranceCoverage     String?
  insuranceExpiry       DateTime?
  bankAccountNumber     String?
  bankIfsc              String?
  bankAccountHolderName String?

  serviceCategories  Category[]
  citiesServed       City[]
  categoryRequests   CategoryRequest[]
  requirementInvites RequirementInvite[]
  bids               Bid[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// society-portal-spec.md Section 4.
model Society {
  id                 String       @id @default(cuid())
  name               String
  address            String
  cityId             String
  city               City         @relation(fields: [cityId], references: [id])
  unitsCount         Int
  registrationNumber String?
  registrantName     String
  registrantRole     RoleName
  registrantPhone    String
  registrantEmail    String
  secretaryName      String
  secretaryPhone     String
  secretaryEmail     String
  status             EntityStatus @default(PENDING_VERIFICATION)
  rejectionReason    String?
  // Default ₹1,000, configurable per society (society spec Section 7).
  approvalThreshold  Int          @default(1000)

  // Standard tier (Section 4.2) — schema-only, no v1 GUI.
  registrationCertificateUrl String?
  panNumber                  String?
  bankAccountNumber          String?
  bankIfsc                   String?
  bankAccountHolderName      String?

  requirements    Requirement[]
  proposedChanges ProposedChange[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum ProposedChangeStatus {
  PENDING
  APPROVED
  REJECTED
}

// Generic "proposed change requires co-approval" mechanism (society-portal-
// spec.md Section 7.1) — applied first to approvalThreshold, one proposer +
// one different Office Bearer's approval, not the 2-of-3 quotation pattern.
model ProposedChange {
  id        String  @id @default(cuid())
  societyId String
  society   Society @relation(fields: [societyId], references: [id], onDelete: Cascade)
  // Field name being changed, e.g. "approvalThreshold" — generic by design
  // so this isn't a one-off table for just the threshold.
  field     String
  oldValue  String
  newValue  String

  proposedByUserId String
  proposedByUser   User    @relation("ProposedChangesProposer", fields: [proposedByUserId], references: [id])
  approvedByUserId String?
  approvedByUser   User?   @relation("ProposedChangesApprover", fields: [approvedByUserId], references: [id])

  status    ProposedChangeStatus @default(PENDING)
  createdAt DateTime             @default(now())
  decidedAt DateTime?
}

enum RequirementUrgency {
  ROUTINE
  URGENT
}

// M6 — society-portal-spec.md Section 7. OPEN covers both "still bidding"
// and "closed, not yet recommended" (distinguished at render time via
// bidDeadline, not a separate stored state). The other three are explicit,
// event-driven states.
enum RequirementStatus {
  OPEN
  AWAITING_APPROVAL
  RETURNED_TO_MANAGER
  FINALIZED
}

// society-portal-spec.md Section 5. Requirement Creation (Manager-only,
// matching engine invite) lands in M5; the model existed a milestone early
// (M4) so the vendor portal had something real to point at.
model Requirement {
  id             String             @id @default(cuid())
  societyId      String
  society        Society            @relation(fields: [societyId], references: [id])
  // Many-to-many (product decision, 2026-07-13): a project can span more than
  // one trade — e.g. waterproofing + painting — and vendors in either trade
  // should be matched, not just ones who do both (see matchVendors).
  categories     Category[]
  name           String
  description    String
  urgency        RequirementUrgency
  // Free text (e.g. "₹10,000 - ₹25,000") — optional, no fixed band list yet.
  budgetBand     String?
  bidDeadline    DateTime
  // File upload storage isn't built (same "schema now, UI later" pattern as
  // KYC document fields elsewhere) — populated by nothing yet, v1 GUI has no
  // upload control.
  attachmentUrls String[]           @default([])

  status      RequirementStatus @default(OPEN)
  finalizedAt DateTime?

  // M7 — deadline-reminders cron (src/app/api/cron/deadline-reminders):
  // stamped the first time each reminder fires, so a still-OPEN requirement
  // never gets the same email/SMS twice on later cron runs.
  deadlineReminderSentAt   DateTime?
  deadlineClosedNotifiedAt DateTime?

  // Manager's recommendation (society-portal-spec.md Section 6).
  recommendedBidId    String?   @unique
  recommendedBid      Bid?      @relation("RequirementRecommendedBid", fields: [recommendedBidId], references: [id])
  // Mandatory if recommendedBid isn't the lowest submitted bid.
  recommendationNote  String?
  recommendedAt       DateTime?
  recommendedByUserId String?
  recommendedByUser   User?     @relation(fields: [recommendedByUserId], references: [id])

  invites            RequirementInvite[]
  bids               Bid[]
  quotationApprovals QuotationApproval[]
  workOrder          WorkOrder?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum ApprovalDecision {
  APPROVED
  REJECTED
}

// One Office Bearer's vote on the *current* recommendation (society-portal-
// spec.md Section 7). Cleared and re-created fresh whenever the Manager
// re-recommends after a RETURNED_TO_MANAGER — see recommendBid in
// src/app/society/[id]/requirements/[reqId]/actions.ts — so stale votes
// from a superseded recommendation never carry over.
model QuotationApproval {
  id                 String           @id @default(cuid())
  requirementId      String
  requirement        Requirement      @relation(fields: [requirementId], references: [id], onDelete: Cascade)
  officeBearerUserId String
  officeBearerUser   User             @relation(fields: [officeBearerUserId], references: [id])
  decision           ApprovalDecision
  decidedAt          DateTime         @default(now())

  @@unique([requirementId, officeBearerUserId])
}

enum FinalizationMethod {
  AUTO_BELOW_THRESHOLD
  OB_APPROVAL
}

// work-order-pdf-spec.md. Society/vendor identity fields are snapshotted at
// finalization time (not read live from Society/VendorCompany) so a
// historical Work Order PDF stays exactly as issued even if those profiles
// change later — see Section 5's storage requirement, done without needing
// a separate blob store since the source rows are already immutable by
// then.
model WorkOrder {
  id                String             @id @default(cuid())
  requirementId     String             @unique
  requirement       Requirement        @relation(fields: [requirementId], references: [id])
  bidId             String             @unique
  bid               Bid                @relation(fields: [bidId], references: [id])
  workOrderNumber   String             @unique
  finalizedVia      FinalizationMethod
  // "Approved by Chairman X, Secretary Y on <date>" or "Finalized by
  // Manager Z — below approval threshold".
  approvalSummary   String
  justificationNote String?

  societyNameSnapshot    String
  societyAddressSnapshot String
  vendorNameSnapshot     String
  vendorAddressSnapshot  String
  vendorContactSnapshot  String

  createdAt DateTime @default(now())
}

// The matched/invited pool for a Requirement (category + city match against
// Active vendors, per society-portal-spec.md Section 5). Only invited
// vendors can see or bid on a Requirement — this is what "blind, matched
// invite" means at the data layer.
model RequirementInvite {
  id              String        @id @default(cuid())
  requirementId   String
  requirement     Requirement   @relation(fields: [requirementId], references: [id], onDelete: Cascade)
  vendorCompanyId String
  vendorCompany   VendorCompany @relation(fields: [vendorCompanyId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())

  @@unique([requirementId, vendorCompanyId])
}

enum BidStatus {
  SUBMITTED
  // Set on finalization (M6) — schema-only for now.
  WON
  NOT_SELECTED
}

// vendor-registration-portal-spec.md Section 8. One Bid per vendor company
// per Requirement (editable up to the deadline); line items are the
// machine-comparable structure the Society side compares post-deadline.
model Bid {
  id                String        @id @default(cuid())
  requirementId     String
  requirement       Requirement   @relation(fields: [requirementId], references: [id], onDelete: Cascade)
  vendorCompanyId   String
  vendorCompany     VendorCompany @relation(fields: [vendorCompanyId], references: [id], onDelete: Cascade)
  submittedByUserId String
  submittedByUser   User          @relation(fields: [submittedByUserId], references: [id])
  totalAmount       Decimal       @db.Decimal(12, 2)
  bidValidity       DateTime
  notes             String?
  status            BidStatus     @default(SUBMITTED)

  lineItems      BidLineItem[]
  recommendedFor Requirement?  @relation("RequirementRecommendedBid")
  workOrder      WorkOrder?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([requirementId, vendorCompanyId])
}

model BidLineItem {
  id          String  @id @default(cuid())
  bidId       String
  bid         Bid     @relation(fields: [bidId], references: [id], onDelete: Cascade)
  description String
  quantity    Decimal @db.Decimal(10, 2)
  // Free text (sqft, nos, lump sum, etc.) — spec calls for a dropdown of
  // common units, not a fixed taxonomy, so this stays a string.
  unit        String
  unitRate    Decimal @db.Decimal(12, 2)
  amount      Decimal @db.Decimal(12, 2)
}
