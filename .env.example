# Neon Postgres. DATABASE_URL is the pooled connection (used at runtime),
# DIRECT_URL is the unpooled connection (used by Prisma for migrations).
DATABASE_URL=""
DIRECT_URL=""

# Auth.js — signs/encrypts session JWTs. Generate with: openssl rand -base64 32
AUTH_SECRET=""

# Google OAuth — https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
# Optional for local dev — email/password login works without them.
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Resend — sends new-registration notifications to the Bluejay team.
# https://resend.com/api-keys
RESEND_API_KEY=""
SUPPORT_EMAIL=""

# Sender address for all outbound emails. Optional — falls back to Resend's
# shared sandbox sender (onboarding@resend.dev), which can only deliver to
# your own Resend account email. Set this to a verified-domain address once
# you've verified a sending domain in Resend (https://resend.com/domains) to
# unlock real delivery to arbitrary recipients.
RESEND_FROM_EMAIL=""

# Anthropic — powers the "Suggest line items" button on the vendor quote
# form (drafts line items from the requirement's description).
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=""
